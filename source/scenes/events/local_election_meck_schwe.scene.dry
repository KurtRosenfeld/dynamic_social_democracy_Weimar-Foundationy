let true_other_share = 0.2;

let total_share = wp_share + true_other_share;

wp_share = (wp_share / total_share);
true_other_share = (true_other_share / total_share);

Q.wp_meck_schwe_elections_vote = Q.other_meck_schwe_elections_vote*wp_share;
