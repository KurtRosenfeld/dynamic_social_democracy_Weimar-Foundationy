    dvp_r_meck_schwe: Q.dvp_r_meck_schwe,
    dnvp_r_meck_schwe: Q.dnvp_r_meck_schwe,
    nsdap_r_meck_schwe: Q.nsdap_r_meck_schwe,
    wp_r_meck_schwe: Q.wp_r_meck_schwe,
    true_other_r_meck_schwe: Q.true_other_r_meck_schwe,
    kvp_r_meck_schwe: Q.kvp_r_meck_schwe,
    dnf_r_meck_schwe: Q.dnf_r_meck_schwe,
    dvfp_r_meck_schwe: Q.dvfp_r_meck_schwe,
    nsfb_r_meck_schwe: Q.nsfb_r_meck_schwe
};

const allocatedSeats = allocateSeats(inputPercentages);

for (const party in allocatedSeats) {
    Q[party] = parseFloat(((allocatedSeats[party] * 100) / 62).toFixed(1));
}

Q.other_r_meck_schwe = Q.wp_r_meck_schwe + Q.true_other_r_meck_schwe;

Q.left_coalition_meck_schwe = parseFloat((Q.spd_r_meck_schwe + Q.kpd_r_meck_schwe + Q.sapd_r_meck_schwe + Q.uspd_r_meck_schwe).toFixed(1));
Q.bourgeois_coalition_meck_schwe = parseFloat((Q.ddp_r_meck_schwe + Q.dvp_r_meck_schwe + Q.lvp_r_meck_schwe + Q.kvp_r_meck_schwe + Q.other_r_meck_schwe + Q.dnvp_r_meck_schwe).toFixed(1));
Q.right_coalition_meck_schwe = parseFloat((Q.dnvp_r_meck_schwe + Q.dvp_r_meck_schwe + Q.dvfp_r_meck_schwe).toFixed(1));
Q.true_bourgeois_coalition_meck_schwe = parseFloat((Q.ddp_r_meck_schwe + Q.dvp_r_meck_schwe + Q.lvp_r_meck_schwe + Q.kvp_r_meck_schwe + Q.other_r_meck_schwe + Q.dnvp_r_meck_schwe).toFixed(1));
Q.social_liberal_coalition_meck_schwe = parseFloat((Q.spd_r_meck_schwe + Q.ddp_r_meck_schwe + Q.lvp_r_meck_schwe + Q.dvp_r_meck_schwe).toFixed(1));

Q.wp_meck_schwe_elections_vote = (Q.wp_meck_schwe_elections_vote != undefined ? parseFloat(Q.wp_meck_schwe_elections_vote.toFixed(1)) : 0);
Q.true_other_meck_schwe_elections_vote = (Q.true_other_meck_schwe_elections_vote != undefined ? parseFloat(Q.true_other_meck_schwe_elections_vote.toFixed(1)) : 0);
Q.wp_r_meck_schwe = (Q.wp_r_meck_schwe != undefined ? parseFloat(Q.wp_r_meck_schwe.toFixed(1)) : 0);
Q.true_other_r_meck_schwe = (Q.true_other_r_meck_schwe != undefined ? parseFloat(Q.true_other_r_meck_schwe.toFixed(1)) : 0);

!}
on-display: {!
data = [{
    "id": "kpd",
    "legend": "KPD",
    "name": "KPD",
    "seats": Math.round(Q.kpd_r_meck_schwe * 0.62),
}];

if (Q.sapd_formed && Q.sapd_r_meck_schwe) {
    data.push({
        "id": "sapd",
        "legend": "SAPD",
        "name": "SAPD",
        "seats": Math.round(Q.sapd_r_meck_schwe * 0.62),
    });
}

if (Q.uspd_r_meck_schwe) {
    data.push({
        "id": "uspd",
        "legend": "USPD",
        "name": "USPD",
        "seats": Math.round(Q.uspd_r_meck_schwe * 0.62),
    });
}
             
data = data.concat([{
    "id": "spd",
    "legend": "SPD",
    "name": "SPD",
    "seats": Math.round(Q.spd_r_meck_schwe * 0.62),
}]);

if (Q.ddp_r_meck_schwe && !Q.lvp_formed) {
    data.push({
        "id": "ddp",
        "legend": Q.ddp_name,
        "name": Q.ddp_name,
        "seats": Math.round(Q.ddp_r_meck_schwe * 0.62),
    });
}

if (Q.lvp_r_meck_schwe && Q.lvp_formed) {
    data.push({
        "id": "lvp",
        "legend": "LVP",
        "name": "LVP",
        "seats": Math.round(Q.lvp_r_meck_schwe * 0.62),
    });
}

if (Q.wp_r_meck_schwe) {
    data.push({
        "id": "wp",
        "legend": "WP",
        "name": "WP",
        "seats": Math.round(Q.wp_r_meck_schwe * 0.62),
    });
}

if (Q.true_other_r_meck_schwe) {
    data.push({
        "id": "other",
        "legend": "Other",
        "name": "Others",
        "seats": Math.round(Q.true_other_r_meck_schwe * 0.62),
    });
}

if (Q.dvp_r_meck_schwe && !Q.lvp_formed && Q.dvp_exist) {
    data.push({
        "id": "dvp",
        "legend": "DVP",
        "name": "DVP",
        "seats": Math.round(Q.dvp_r_meck_schwe * 0.62),
    });
}

if (Q.kvp_formed && Q.kvp_r_meck_schwe) {
    data.push({
        "id": "kvp",
        "legend": "KVP",
        "name": "KVP",
        "seats": Math.round(Q.kvp_r_meck_schwe * 0.62),
    });
}

data = data.concat([{
    "id": "dnvp",
    "legend": "DNVP",
    "name": "DNVP",
    "seats": Math.round(Q.dnvp_r_meck_schwe * 0.62),
}]);

if (Q.dnf_formed && Q.dnf_r_meck_schwe) {
    data.push({
        "id": "dnf",
        "legend": "DNF",
        "name": "DNF",
        "seats": Math.round(Q.dnf_r_meck_schwe * 0.62),
    });
}

data.push({
    "id": "dvfp",
    "legend": "DVFP",
    "name": "DVFP",
    "seats": Math.round(Q.dvfp_r_meck_schwe * 0.62),
    "color": "#3D3D3D"
});

data.push({
    "id": "nsfb",
    "legend": "NSFB",
    "name": "NSFB",
    "seats": Math.round(Q.nsfb_r_meck_schwe * 0.62),
    "color": "#59250F"
});

data = data.concat([{
    "id": "nsdap",
    "legend": "NSDAP",
    "name": "NSDAP",
    "seats": Math.round(Q.nsdap_r_meck_schwe * 0.62),
}]);

if (window && d3) {
    var width = 500;
    var height = 500;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50;
        height = width;
        document.getElementById("meck_schwe_landtag").style.height = screenWidth/2 + "px";
    }
    var parliament = d3.parliament();
    parliament.width(width).height(height).innerRadiusCoef(0.4);
    parliament.enter.fromCenter(true).smallToBig(true);
    parliament.exit.toCenter(false).bigToSmall(true);
    d3.select("#meck_schwe_landtag").datum(data).call(parliament);
}
!}
