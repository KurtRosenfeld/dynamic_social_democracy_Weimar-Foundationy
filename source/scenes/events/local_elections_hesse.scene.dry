title: Hesse Landtag Election
view-if: (year == 1922 and month == 12 and not hesse_election_seen) or (hesse_election_2_trigger_time == time and hesse_election_seen_time != time)
new-page: true
tags: event
on-arrival: hesse_election_seen += 1 if hesse_election_seen; hesse_election_seen = 1 if not hesse_election_seen; hesse_election_seen_time = time
priority: 2
on-display: {!  
    var cardEl = document.createElement('div');  
    cardEl.className = "face-figure2";  

    var image = new Image();  
    image.className = "face-img";  
    image.src = "img/states.png";  

    cardEl.appendChild(image);  
    var contentDiv = document.querySelector("#page #mid_panel #content");
    contentDiv.appendChild(cardEl);
!}

= Elections, [+ month : month +] [+ year +]

The Hesse state elections are to be held now.

- @hesse: May we do our best...

@hesse
on-arrival: {!

var hesse_adjustment_factors = {
    spd: 1.27,
    sapd: 1.2,
    uspd: 1.11,
    kpd: 0.82,
    z: 1.13,
    ddp: 1.1,
    lvp: 1.03,
    dvp: 1.01,
    dnvp: 0.28,
    nsdap: 1.1,
    nsfb: 0.6,
    other: 3.7,
    kvp: 0.5,
    dnf: 0.33
};

Q.spd_r_hesse = 0;
Q.sapd_r_hesse = 0;
Q.uspd_r_hesse = 0;
Q.kpd_r_hesse = 0;
Q.ddp_r_hesse = 0;
Q.lvp_r_hesse = 0;
Q.dvp_r_hesse = 0;
Q.dnvp_r_hesse = 0;
Q.nsdap_r_hesse = 0;
Q.z_r_hesse = 0;
Q.nsfb_r_hesse = 0;
Q.other_r_hesse = 0;
