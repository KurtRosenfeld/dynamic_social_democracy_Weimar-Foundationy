    dnvp: 0.26,
    nsdap: 1.1,
    nsfb: 0.6,
    other: 3.7,
    kvp: 0.6,
    dnf: 0.33
};

Q.spd_r_hesse = 0;
Q.sapd_r_hesse = 0;
Q.uspd_r_hesse = 0;
Q.kpd_r_hesse = 0;
Q.ddp_r_hesse = 0;
Q.lvp_r_hesse = 0;
Q.dvp_r_hesse = 0;
Q.dnvp_r_hesse = 0;
Q.nsdap_r_hesse = 0;
