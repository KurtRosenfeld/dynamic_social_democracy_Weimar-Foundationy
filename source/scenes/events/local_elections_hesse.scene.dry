Q.spd_hesse_elections_vote = 0;
Q.sapd_hesse_elections_vote = 0;
Q.uspd_hesse_elections_vote = 0;
Q.kpd_hesse_elections_vote = 0;
Q.ddp_hesse_elections_vote = 0;
Q.lvp_hesse_elections_vote = 0;
Q.dvp_hesse_elections_vote = 0;
Q.dnvp_hesse_elections_vote = 0;
Q.nsdap_hesse_elections_vote = 0;
Q.z_hesse_elections_vote = 0;
Q.nsfb_hesse_elections_vote = 0;
Q.other_hesse_elections_vote = 0;
Q.kvp_hesse_elections_vote = 0;
Q.dnf_hesse_elections_vote = 0;

if (Q.new_middle_spd_normalized + Q.old_middle_spd_normalized >= 30) hesse_adjustment_factors.spd += 0.1;
if (Q.spd_r < 100) hesse_adjustment_factors.uspd += 0.3;
if (Q.spd_r < 70) hesse_adjustment_factors.kpd += 0.1;
if (Q.workers_spd_normalized >= 70) hesse_adjustment_factors.spd += 0.1;
Q.spd_hesse_elections_vote = Q.spd_votes*hesse_adjustment_factors.spd;
Q.sapd_hesse_elections_vote = Q.sapd_votes*hesse_adjustment_factors.sapd;
Q.uspd_hesse_elections_vote = Q.uspd_votes*hesse_adjustment_factors.uspd;
Q.kpd_hesse_elections_vote = Q.kpd_votes*hesse_adjustment_factors.kpd;
if (Q.stolper_program_adopted) hesse_adjustment_factors.ddp += 0.2;
Q.ddp_hesse_elections_vote = Q.ddp_votes*hesse_adjustment_factors.ddp;
Q.lvp_hesse_elections_vote = Q.lvp_votes*hesse_adjustment_factors.lvp;
Q.dvp_hesse_elections_vote = Q.dvp_votes*hesse_adjustment_factors.dvp;
if (Q.dnvp_ideology == "Moderate") hesse_adjustment_factors.dnvp -= 0.1;
Q.dnvp_hesse_elections_vote = Q.dnvp_votes*hesse_adjustment_factors.dnvp;
