[? if lvp_formed: {!<tr><td><div class="box" style='background-color:#FFCC00'> </div> !} LVP: {!</td><td!} **[+ lvp_hesse_elections_vote +]%** {!</td><td!} **[+ lvp_r_hesse +]%**  {!</td></tr>!} ?]

[? if not lvp_formed: {!<tr><td><div class="box" style='background-color:#D5AC27'> </div> !} DVP: {!</td><td!} **[+ dvp_hesse_elections_vote +]%** {!</td><td!} **[+ dvp_r_hesse +]%**  {!</td></tr>!} ?]

