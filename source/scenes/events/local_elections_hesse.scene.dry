    Q.lvp_hesse_elections_vote = (Q.lvp_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.dvp_hesse_elections_vote = (Q.dvp_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.dnvp_hesse_elections_vote = (Q.dnvp_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.nsdap_hesse_elections_vote = (Q.nsdap_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.other_hesse_elections_vote = (Q.other_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.kvp_hesse_elections_vote = (Q.kvp_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.dnf_hesse_elections_vote = (Q.dnf_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.z_hesse_elections_vote = (Q.z_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.nsfb_hesse_elections_vote = (Q.nsfb_hesse_elections_vote / Q.total_votes_hesse) * 100;
    let target = 34;
    Q.spd_hesse_elections_vote = Math.round((Q.spd_hesse_elections_vote + (target - Q.spd_hesse_elections_vote) * 0.35) * 10) / 10;
    Q.total_votes_hesse = Q.spd_hesse_elections_vote + Q.sapd_hesse_elections_vote + Q.kpd_hesse_elections_vote + Q.ddp_hesse_elections_vote + Q.lvp_hesse_elections_vote + Q.dvp_hesse_elections_vote + Q.dnvp_hesse_elections_vote + Q.nsdap_hesse_elections_vote + Q.other_hesse_elections_vote + Q.kvp_hesse_elections_vote + Q.dnf_hesse_elections_vote + Q.uspd_hesse_elections_vote + Q.z_hesse_elections_vote + Q.nsfb_hesse_elections_vote;
    Q.spd_hesse_elections_vote = (Q.spd_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.sapd_hesse_elections_vote = (Q.sapd_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.uspd_hesse_elections_vote = (Q.uspd_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.kpd_hesse_elections_vote = (Q.kpd_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.ddp_hesse_elections_vote = (Q.ddp_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.lvp_hesse_elections_vote = (Q.lvp_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.dvp_hesse_elections_vote = (Q.dvp_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.dnvp_hesse_elections_vote = (Q.dnvp_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.nsdap_hesse_elections_vote = (Q.nsdap_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.other_hesse_elections_vote = (Q.other_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.kvp_hesse_elections_vote = (Q.kvp_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.dnf_hesse_elections_vote = (Q.dnf_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.z_hesse_elections_vote = (Q.z_hesse_elections_vote / Q.total_votes_hesse) * 100;
    Q.nsfb_hesse_elections_vote = (Q.nsfb_hesse_elections_vote / Q.total_votes_hesse) * 100;
}

Q.spd_hesse_elections_vote = (Q.spd_hesse_elections_vote != undefined ? parseFloat(Q.spd_hesse_elections_vote.toFixed(1)) : 0);
Q.sapd_hesse_elections_vote = (Q.sapd_hesse_elections_vote != undefined ? parseFloat(Q.sapd_hesse_elections_vote.toFixed(1)) : 0);
Q.uspd_hesse_elections_vote = (Q.uspd_hesse_elections_vote != undefined ? parseFloat(Q.uspd_hesse_elections_vote.toFixed(1)) : 0);
Q.kpd_hesse_elections_vote = (Q.kpd_hesse_elections_vote != undefined ? parseFloat(Q.kpd_hesse_elections_vote.toFixed(1)) : 0);
Q.ddp_hesse_elections_vote = (Q.ddp_hesse_elections_vote != undefined ? parseFloat(Q.ddp_hesse_elections_vote.toFixed(1)) : 0);
Q.lvp_hesse_elections_vote = (Q.lvp_hesse_elections_vote != undefined ? parseFloat(Q.lvp_hesse_elections_vote.toFixed(1)) : 0);
Q.dvp_hesse_elections_vote = (Q.dvp_hesse_elections_vote != undefined ? parseFloat(Q.dvp_hesse_elections_vote.toFixed(1)) : 0);
Q.dnvp_hesse_elections_vote = (Q.dnvp_hesse_elections_vote != undefined ? parseFloat(Q.dnvp_hesse_elections_vote.toFixed(1)) : 0);
Q.nsdap_hesse_elections_vote = (Q.nsdap_hesse_elections_vote != undefined ? parseFloat(Q.nsdap_hesse_elections_vote.toFixed(1)) : 0);
Q.other_hesse_elections_vote = (Q.other_hesse_elections_vote != undefined ? parseFloat(Q.other_hesse_elections_vote.toFixed(1)) : 0);
Q.kvp_hesse_elections_vote = (Q.kvp_hesse_elections_vote != undefined ? parseFloat(Q.kvp_hesse_elections_vote.toFixed(1)) : 0);
Q.dnf_hesse_elections_vote = (Q.dnf_hesse_elections_vote != undefined ? parseFloat(Q.dnf_hesse_elections_vote.toFixed(1)) : 0);
Q.z_hesse_elections_vote = (Q.z_hesse_elections_vote != undefined ? parseFloat(Q.z_hesse_elections_vote.toFixed(1)) : 0);
Q.nsfb_hesse_elections_vote = (Q.nsfb_hesse_elections_vote != undefined ? parseFloat(Q.nsfb_hesse_elections_vote.toFixed(1)) : 0);

if (Q.spd_hesse_elections_vote >= 1.4) Q.spd_r_hesse = Q.spd_hesse_elections_vote;
if (Q.sapd_hesse_elections_vote >= 1.4) Q.sapd_r_hesse = Q.sapd_hesse_elections_vote;
if (Q.uspd_hesse_elections_vote >= 1.4) Q.uspd_r_hesse = Q.uspd_hesse_elections_vote;
