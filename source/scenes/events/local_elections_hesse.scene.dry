title: Hesse Landtag Election
view-if: (year == 1924 and month == 12 and not hesse_election_seen) or (hesse_election_2_trigger_time == time and hesse_election_seen_time != time)
new-page: true
tags: event
on-arrival: hesse_election_seen += 1 if hesse_election_seen; hesse_election_seen = 1 if not hesse_election_seen; hesse_election_seen_time = time
priority: 2
on-display: {!  
    var cardEl = document.createElement('div');  
    cardEl.className = "face-figure2";  

    var image = new Image();  
    image.className = "face-img";  
    image.src = "img/states.png";  

    cardEl.appendChild(image);  
    var contentDiv = document.querySelector("#page #mid_panel #content");
    contentDiv.appendChild(cardEl);
!}

= Elections, [+ month : month +] [+ year +]

The Hesse state elections are to be held now.

- @hesse: May we do our best...

@hesse
on-arrival: {!

var meck_schwe_adjustment_factors = {
    spd: 1.27,
