Q.farm_meck_schwe_elections_vote = Q.other_meck_schwe_elections_vote*farm_share;
Q.farm_r_meck_schwe = Q.other_r_meck_schwe*farm_share;

Q.wp_meck_schwe_elections_vote = Q.other_meck_schwe_elections_vote*wp_share;
Q.wp_r_meck_schwe = Q.other_r_meck_schwe*wp_share;

Q.vrp_meck_schwe_elections_vote = Q.other_meck_schwe_elections_vote*vrp_share;
Q.vrp_r_meck_schwe = Q.other_r_meck_schwe*vrp_share;

Q.kpo_meck_schwe_elections_vote = Q.kpd_meck_schwe_elections_vote*0.06
Q.kpd_meck_schwe_elections_vote -= Q.kpo_meck_schwe_elections_vote;

function allocateSeats(percentages, totalSeats = 96) {
    const exactSeats = {};
    const flooredSeats = {};
    const remainders = [];

    let totalFlooredSeats = 0;
    for (const party in percentages) {
        const exact = (percentages[party] * totalSeats) / 100;
        const floored = Math.floor(exact);
        const remainder = exact - floored;

        exactSeats[party] = exact;
        flooredSeats[party] = floored;
        totalFlooredSeats += floored;

        remainders.push({ party, remainder });
    }

    const seatsToDistribute = totalSeats - totalFlooredSeats;
    remainders.sort((a, b) => b.remainder - a.remainder);

    for (let i = 0; i < seatsToDistribute; i++) {
        flooredSeats[remainders[i].party]++;
    }

    return flooredSeats;
}

const inputPercentages = {
    spd_r_meck_schwe: Q.spd_r_meck_schwe,
    uspd_r_meck_schwe: Q.uspd_r_meck_schwe,
    sapd_r_meck_schwe: Q.sapd_r_meck_schwe,
    kpd_r_meck_schwe: Q.kpd_r_meck_schwe,
    ddp_r_meck_schwe: Q.ddp_r_meck_schwe,
    lvp_r_meck_schwe: Q.lvp_r_meck_schwe,
    z_r_meck_schwe: Q.z_r_meck_schwe,
    dvp_r_meck_schwe: Q.dvp_r_meck_schwe,
    dnvp_r_meck_schwe: Q.dnvp_r_meck_schwe,
    nsdap_r_meck_schwe: Q.nsdap_r_meck_schwe,
    wp_r_meck_schwe: Q.wp_r_meck_schwe,
    farm_r_meck_schwe: Q.farm_r_meck_schwe,
    vrp_r_meck_schwe: Q.vrp_r_meck_schwe,
    kvp_r_meck_schwe: Q.kvp_r_meck_schwe,
    dnf_r_meck_schwe: Q.dnf_r_meck_schwe
};

const allocatedSeats = allocateSeats(inputPercentages);

for (const party in allocatedSeats) {
    Q[party] = parseFloat(((allocatedSeats[party] * 100) / 96).toFixed(1));
}

Q.other_r_meck_schwe = Q.farm_r_meck_schwe + Q.wp_r_meck_schwe + Q.vrp_r_meck_schwe;

Q.left_coalition_meck_schwe = parseFloat((Q.spd_r_meck_schwe + Q.kpd_r_meck_schwe + Q.sapd_r_meck_schwe + Q.uspd_r_meck_schwe).toFixed(1));
Q.bourgeois_coalition_meck_schwe = parseFloat((Q.z_r_meck_schwe + Q.ddp_r_meck_schwe + Q.dvp_r_meck_schwe + Q.lvp_r_meck_schwe + Q.kvp_r_meck_schwe + Q.other_r_meck_schwe + Q.dnvp_r_meck_schwe + Q.nsdap_r_meck_schwe).toFixed(1));
Q.true_bourgeois_coalition_meck_schwe = parseFloat((Q.z_r_meck_schwe + Q.ddp_r_meck_schwe + Q.dvp_r_meck_schwe + Q.lvp_r_meck_schwe + Q.kvp_r_meck_schwe + Q.other_r_meck_schwe + Q.dnvp_r_meck_schwe).toFixed(1));
Q.spd_coalition_meck_schwe = parseFloat((Q.spd_r_meck_schwe + Q.ddp_r_meck_schwe + Q.lvp_r_meck_schwe + Q.z_r_meck_schwe + Q.dvp_r_meck_schwe).toFixed(1));

Q.farm_meck_schwe_elections_vote = (Q.farm_meck_schwe_elections_vote != undefined ? parseFloat(Q.farm_meck_schwe_elections_vote.toFixed(1)) : 0);
Q.wp_meck_schwe_elections_vote = (Q.wp_meck_schwe_elections_vote != undefined ? parseFloat(Q.wp_meck_schwe_elections_vote.toFixed(1)) : 0);
Q.vrp_meck_schwe_elections_vote = (Q.vrp_meck_schwe_elections_vote != undefined ? parseFloat(Q.vrp_meck_schwe_elections_vote.toFixed(1)) : 0);
Q.kpo_meck_schwe_elections_vote = (Q.kpo_meck_schwe_elections_vote != undefined ? parseFloat(Q.kpo_meck_schwe_elections_vote.toFixed(1)) : 0);
Q.kpd_meck_schwe_elections_vote = (Q.kpd_meck_schwe_elections_vote != undefined ? parseFloat(Q.kpd_meck_schwe_elections_vote.toFixed(1)) : 0);
Q.aspd_meck_schwe_elections_vote = (Q.aspd_meck_schwe_elections_vote != undefined ? parseFloat(Q.aspd_meck_schwe_elections_vote.toFixed(1)) : 0);
Q.spd_meck_schwe_elections_vote = (Q.spd_meck_schwe_elections_vote != undefined ? parseFloat(Q.spd_meck_schwe_elections_vote.toFixed(1)) : 0);
Q.farm_r_meck_schwe = (Q.farm_r_meck_schwe != undefined ? parseFloat(Q.farm_r_meck_schwe.toFixed(1)) : 0);
Q.wp_r_meck_schwe = (Q.wp_r_meck_schwe != undefined ? parseFloat(Q.wp_r_meck_schwe.toFixed(1)) : 0);
Q.vrp_r_meck_schwe = (Q.vrp_r_meck_schwe != undefined ? parseFloat(Q.vrp_r_meck_schwe.toFixed(1)) : 0);
Q.uspd_r_meck_schwe = (Q.uspd_r_meck_schwe != undefined ? parseFloat(Q.uspd_r_meck_schwe.toFixed(1)) : 0);
Q.spd_r_meck_schwe = (Q.spd_r_meck_schwe != undefined ? parseFloat(Q.spd_r_meck_schwe.toFixed(1)) : 0);

!}
on-display: {!
data = [{
