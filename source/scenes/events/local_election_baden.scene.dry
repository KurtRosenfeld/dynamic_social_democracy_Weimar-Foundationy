subtitle: [? if z_r_baden >= spd_r_baden: The <span style="color: [+ z_colour +];">Center Party</span> demands the minister-president. ?]
on-arrival: baden_coalition_r = baden_coalition_r += z_r_baden; baden_z = "government"
go-to: baden_coalition_creator

@baden_invite_dvp
view-if: dvp_r_baden > 0 and not baden_dvp = "government"
