subtitle: The <span style="color: [+ dvp_colour +];">**DVP**</span> demands tax cuts.
on-arrival: baden_coalition_r = baden_coalition_r += dvp_r_baden; baden_dvp = "government"
go-to: baden_coalition_creator

@baden_invite_others
view-if: true_other_r_baden > 0 and not baden_true_others = "government"
