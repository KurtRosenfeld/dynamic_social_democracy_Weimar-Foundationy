- @baden_drop_dvp: Drop the <span style="color: [+ dvp_colour +];">**DVP**</span>
- @baden_drop_wp: Drop the <span style="color: #b8996f;">**WP**</span>


@baden_invite_kpd
view-if: kpd_r_baden > 0 and not baden_kpd = "government"
choose-if: kpd_relation >= 65 and baden_dvp == "opposition" and baden_wp == "opposition"
subtitle: The <span style="color: [+ kpd_colour +];">**KPD**</span> will demand radical policies.
on-arrival: baden_coalition_r = baden_coalition_r += kpd_r_baden; baden_kpd = "government"
go-to: baden_coalition_creator

@baden_invite_sapd
view-if: sapd_r_baden > 0 and not baden_sapd = "government"
choose-if: sapd_relation >= 60
subtitle: The <span style="color: [+ sapd_colour +];">**SAPD**</span> will demand radical policies.
on-arrival: baden_coalition_r = baden_coalition_r += sapd_r_baden; baden_sapd = "government"
go-to: baden_coalition_creator

@baden_invite_uspd
view-if: uspd_r_baden > 0 and not baden_uspd = "government"
choose-if: uspd_relation >= 50
subtitle: [? if not uspd_ideology == "Orthodox Marxism": The <span style="color: [+ uspd_colour +];">**USPD**</span> will demand radical policies. ?][? if uspd_ideology == "Orthodox Marxism": Center Marxists are flexible. ?]
on-arrival: baden_coalition_r = baden_coalition_r += uspd_r_baden; baden_uspd = "government"
go-to: baden_coalition_creator

@baden_invite_ddp
view-if: ddp_r_baden > 0 and not baden_ddp = "government"
choose-if: ddp_relation >= 45
subtitle: [? if ddp_relation >= 65: The <span style="color: [+ ddp_colour +];">**DDP**</span> loves you! ?]
on-arrival: baden_coalition_r = baden_coalition_r += ddp_r_baden; baden_ddp = "government"
go-to: baden_coalition_creator

@baden_invite_z
