title: Baden Landtag Election
view-if: (year == 1922 and month == 4 and not baden_election_seen) or (baden_election_2_trigger_time == time and baden_election_seen_time != time)
new-page: true
tags: event
on-arrival: baden_election_seen += 1 if baden_election_seen; baden_election_seen = 1 if not baden_election_seen; baden_election_seen_time = time
priority: 3
on-display: {!  
    var cardEl = document.createElement('div');  
    cardEl.className = "face-figure2";  

    var image = new Image();  
    image.className = "face-img";  
    image.src = "img/states.png";  

    cardEl.appendChild(image);  
    var contentDiv = document.querySelector("#page #mid_panel #content");
    contentDiv.appendChild(cardEl);
!}

= Elections, [+ month : month +] [+ year +]

The Baden state elections are to be held now.

- @baden: May we do our best...

@baden
on-arrival: {!

var baden_adjustment_factors = {
    spd: 0.8,
    sapd: 0.2,
    uspd: 0.4,
    kpd: 0.7,
    z: 2.05,
    ddp: 0.8,
    lvp: 0.83,
    dvp: 0.94,
    dnvp: 0.6,
    nsdap: 1.15,
    nsfb: 0.4,
    other: 0.65,
    kvp: 0.3,
    dnf: 0.2
};

Q.spd_r_baden = 0;
Q.sapd_r_baden = 0;
Q.uspd_r_baden = 0;
Q.kpd_r_baden = 0;
Q.ddp_r_baden = 0;
Q.lvp_r_baden = 0;
Q.dvp_r_baden = 0;
Q.dnvp_r_baden = 0;
Q.nsdap_r_baden = 0;
Q.z_r_baden = 0;
Q.nsfb_r_baden = 0;
Q.other_r_baden = 0;
Q.kvp_r_baden = 0;
Q.dnf_r_baden = 0;

Q.spd_baden_elections_vote = 0;
Q.sapd_baden_elections_vote = 0;
Q.uspd_baden_elections_vote = 0;
Q.kpd_baden_elections_vote = 0;
Q.ddp_baden_elections_vote = 0;
Q.lvp_baden_elections_vote = 0;
Q.dvp_baden_elections_vote = 0;
Q.dnvp_baden_elections_vote = 0;
Q.nsdap_baden_elections_vote = 0;
Q.z_baden_elections_vote = 0;
Q.nsfb_baden_elections_vote = 0;
Q.other_baden_elections_vote = 0;
Q.kvp_baden_elections_vote = 0;
Q.dnf_baden_elections_vote = 0;

if (Q.catholic_spd_normalized >= 30) baden_adjustment_factors.spd += 0.2;
Q.spd_baden_elections_vote = Q.spd_votes*baden_adjustment_factors.spd;
Q.sapd_baden_elections_vote = Q.sapd_votes*baden_adjustment_factors.sapd;
if (Q.unions_independent == 1) baden_adjustment_factors.uspd += 0.1;
Q.uspd_baden_elections_vote = Q.uspd_votes*baden_adjustment_factors.uspd;
Q.kpd_baden_elections_vote = Q.kpd_votes*baden_adjustment_factors.kpd;
Q.ddp_baden_elections_vote = Q.ddp_votes*baden_adjustment_factors.ddp;
Q.lvp_baden_elections_vote = Q.lvp_votes*baden_adjustment_factors.lvp;
Q.dvp_baden_elections_vote = Q.dvp_votes*baden_adjustment_factors.dvp;
if (Q.cnbl_exists) baden_adjustment_factors.dnvp -= 0.15;
Q.dnvp_baden_elections_vote = Q.dnvp_votes*baden_adjustment_factors.dnvp;
Q.nsdap_baden_elections_vote = Q.nsdap_votes*baden_adjustment_factors.nsdap;
Q.z_baden_elections_vote = Q.z_votes*baden_adjustment_factors.z;
Q.nsfb_baden_elections_vote = Q.nsfb_votes*baden_adjustment_factors.nsfb;
if (Q.stolper_program_adopted) baden_adjustment_factors.other -= 0.1;
if (Q.cnbl_exists) baden_adjustment_factors.other += 0.2;
Q.other_baden_elections_vote = Q.other_votes*baden_adjustment_factors.other;
Q.kvp_baden_elections_vote = Q.kvp_votes*baden_adjustment_factors.kvp;
Q.dnf_baden_elections_vote = Q.dnf_votes*baden_adjustment_factors.dnf;

Q.total_votes_baden = Q.spd_baden_elections_vote + Q.sapd_baden_elections_vote + Q.kpd_baden_elections_vote + Q.ddp_baden_elections_vote + Q.lvp_baden_elections_vote + Q.dvp_baden_elections_vote + Q.dnvp_baden_elections_vote + Q.nsdap_baden_elections_vote + Q.other_baden_elections_vote + Q.kvp_baden_elections_vote + Q.dnf_baden_elections_vote + Q.uspd_baden_elections_vote + Q.z_baden_elections_vote + Q.nsfb_baden_elections_vote;

if (Q.total_votes_baden > 0) {
    Q.spd_baden_elections_vote = (Q.spd_baden_elections_vote / Q.total_votes_baden) * 100;
    Q.sapd_baden_elections_vote = (Q.sapd_baden_elections_vote / Q.total_votes_baden) * 100;
    Q.uspd_baden_elections_vote = (Q.uspd_baden_elections_vote / Q.total_votes_baden) * 100;
    Q.kpd_baden_elections_vote = (Q.kpd_baden_elections_vote / Q.total_votes_baden) * 100;
    Q.ddp_baden_elections_vote = (Q.ddp_baden_elections_vote / Q.total_votes_baden) * 100;
    Q.lvp_baden_elections_vote = (Q.lvp_baden_elections_vote / Q.total_votes_baden) * 100;
    Q.dvp_baden_elections_vote = (Q.dvp_baden_elections_vote / Q.total_votes_baden) * 100;
    Q.dnvp_baden_elections_vote = (Q.dnvp_baden_elections_vote / Q.total_votes_baden) * 100;
    Q.nsdap_baden_elections_vote = (Q.nsdap_baden_elections_vote / Q.total_votes_baden) * 100;
    Q.other_baden_elections_vote = (Q.other_baden_elections_vote / Q.total_votes_baden) * 100;
    Q.kvp_baden_elections_vote = (Q.kvp_baden_elections_vote / Q.total_votes_baden) * 100;
    Q.dnf_baden_elections_vote = (Q.dnf_baden_elections_vote / Q.total_votes_baden) * 100;
    Q.z_baden_elections_vote = (Q.z_baden_elections_vote / Q.total_votes_baden) * 100;
    Q.nsfb_baden_elections_vote = (Q.nsfb_baden_elections_vote / Q.total_votes_baden) * 100;
}

Q.spd_baden_elections_vote = (Q.spd_baden_elections_vote != undefined ? parseFloat(Q.spd_baden_elections_vote.toFixed(1)) : 0);
Q.sapd_baden_elections_vote = (Q.sapd_baden_elections_vote != undefined ? parseFloat(Q.sapd_baden_elections_vote.toFixed(1)) : 0);
Q.uspd_baden_elections_vote = (Q.uspd_baden_elections_vote != undefined ? parseFloat(Q.uspd_baden_elections_vote.toFixed(1)) : 0);
Q.kpd_baden_elections_vote = (Q.kpd_baden_elections_vote != undefined ? parseFloat(Q.kpd_baden_elections_vote.toFixed(1)) : 0);
Q.ddp_baden_elections_vote = (Q.ddp_baden_elections_vote != undefined ? parseFloat(Q.ddp_baden_elections_vote.toFixed(1)) : 0);
Q.lvp_baden_elections_vote = (Q.lvp_baden_elections_vote != undefined ? parseFloat(Q.lvp_baden_elections_vote.toFixed(1)) : 0);
Q.dvp_baden_elections_vote = (Q.dvp_baden_elections_vote != undefined ? parseFloat(Q.dvp_baden_elections_vote.toFixed(1)) : 0);
Q.dnvp_baden_elections_vote = (Q.dnvp_baden_elections_vote != undefined ? parseFloat(Q.dnvp_baden_elections_vote.toFixed(1)) : 0);
Q.nsdap_baden_elections_vote = (Q.nsdap_baden_elections_vote != undefined ? parseFloat(Q.nsdap_baden_elections_vote.toFixed(1)) : 0);
Q.other_baden_elections_vote = (Q.other_baden_elections_vote != undefined ? parseFloat(Q.other_baden_elections_vote.toFixed(1)) : 0);
Q.kvp_baden_elections_vote = (Q.kvp_baden_elections_vote != undefined ? parseFloat(Q.kvp_baden_elections_vote.toFixed(1)) : 0);
Q.dnf_baden_elections_vote = (Q.dnf_baden_elections_vote != undefined ? parseFloat(Q.dnf_baden_elections_vote.toFixed(1)) : 0);
Q.z_baden_elections_vote = (Q.z_baden_elections_vote != undefined ? parseFloat(Q.z_baden_elections_vote.toFixed(1)) : 0);
Q.nsfb_baden_elections_vote = (Q.nsfb_baden_elections_vote != undefined ? parseFloat(Q.nsfb_baden_elections_vote.toFixed(1)) : 0);

if (Q.spd_baden_elections_vote >= 1.4) Q.spd_r_baden = Q.spd_baden_elections_vote;
if (Q.sapd_baden_elections_vote >= 1.8) Q.sapd_r_baden = Q.sapd_baden_elections_vote;
if (Q.uspd_baden_elections_vote >= 1.8) Q.uspd_r_baden = Q.uspd_baden_elections_vote;
if (Q.kpd_baden_elections_vote >= 1.8) Q.kpd_r_baden = Q.kpd_baden_elections_vote;
if (Q.ddp_baden_elections_vote >= 1.5) Q.ddp_r_baden = Q.ddp_baden_elections_vote;
if (Q.lvp_baden_elections_vote >= 1.4) Q.lvp_r_baden = Q.lvp_baden_elections_vote;
if (Q.dvp_baden_elections_vote >= 1.4) Q.dvp_r_baden = Q.dvp_baden_elections_vote;
if (Q.dnvp_baden_elections_vote >= 1.4) Q.dnvp_r_baden = Q.dnvp_baden_elections_vote;
if (Q.nsdap_baden_elections_vote >= 1.4) Q.nsdap_r_baden = Q.nsdap_baden_elections_vote;
if (Q.other_baden_elections_vote >= 0.4) Q.other_r_baden = Q.other_baden_elections_vote;
if (Q.kvp_baden_elections_vote >= 1.4) Q.kvp_r_baden = Q.kvp_baden_elections_vote;
if (Q.dnf_baden_elections_vote >= 1.4) Q.dnf_r_baden = Q.dnf_baden_elections_vote;
if (Q.z_baden_elections_vote >= 1.4) Q.z_r_baden = Q.z_baden_elections_vote;
if (Q.nsfb_baden_elections_vote >= 1.4) Q.nsfb_r_baden = Q.nsfb_baden_elections_vote;

var baden_adjustment_r_factors = {
    spd: 1.0,
    sapd: 1.0,
    uspd: 1.0,
    kpd: 1.0,
    ddp: 0.97,
    lvp: 1.0,
    dvp: 1.0,
    dnvp: 1.0,
    nsdap: 1.0,
    other: 1.0,
    kvp: 0.7,
    dnf: 0.7,
    z: 1.0,
    nsfb: 1.0
};

Q.spd_r_baden = Q.spd_r_baden*baden_adjustment_r_factors.spd;
Q.sapd_r_baden = Q.sapd_r_baden*baden_adjustment_r_factors.sapd;
Q.uspd_r_baden = Q.uspd_r_baden*baden_adjustment_r_factors.uspd;
Q.kpd_r_baden = Q.kpd_r_baden*baden_adjustment_r_factors.kpd;
Q.ddp_r_baden = Q.ddp_r_baden*baden_adjustment_r_factors.ddp;
Q.lvp_r_baden = Q.lvp_r_baden*baden_adjustment_r_factors.lvp;
Q.dvp_r_baden = Q.dvp_r_baden*baden_adjustment_r_factors.dvp;
Q.dnvp_r_baden = Q.dnvp_r_baden*baden_adjustment_r_factors.dnvp;
Q.nsdap_r_baden = Q.nsdap_r_baden*baden_adjustment_r_factors.nsdap;
Q.other_r_baden = Q.other_r_baden*baden_adjustment_r_factors.other;
Q.kvp_r_baden = Q.kvp_r_baden*baden_adjustment_r_factors.kvp;
Q.dnf_r_baden = Q.dnf_r_baden*baden_adjustment_r_factors.dnf;
Q.z_r_baden = Q.z_r_baden*baden_adjustment_r_factors.z;
Q.nsfb_r_baden = Q.nsfb_r_baden*baden_adjustment_r_factors.nsfb;

Q.total_r_baden = 0;

if (Q.spd_r_baden) Q.total_r_baden += Q.spd_r_baden;
if (Q.sapd_r_baden) Q.total_r_baden += Q.sapd_r_baden;
if (Q.uspd_r_baden) Q.total_r_baden += Q.uspd_r_baden;
if (Q.kpd_r_baden) Q.total_r_baden += Q.kpd_r_baden;
if (Q.ddp_r_baden) Q.total_r_baden += Q.ddp_r_baden;
if (Q.lvp_r_baden) Q.total_r_baden += Q.lvp_r_baden;
if (Q.dvp_r_baden) Q.total_r_baden += Q.dvp_r_baden;
if (Q.dnvp_r_baden) Q.total_r_baden += Q.dnvp_r_baden;
if (Q.nsdap_r_baden) Q.total_r_baden += Q.nsdap_r_baden;
if (Q.other_r_baden) Q.total_r_baden += Q.other_r_baden;
if (Q.kvp_r_baden) Q.total_r_baden += Q.kvp_r_baden;
if (Q.dnf_r_baden) Q.total_r_baden += Q.dnf_r_baden;
if (Q.z_r_baden) Q.total_r_baden += Q.z_r_baden;
if (Q.nsfb_r_baden) Q.total_r_baden += Q.nsfb_r_baden;

if (Q.total_r_baden > 0) {
    Q.spd_r_baden = (Q.spd_r_baden / Q.total_r_baden) * 100;
    Q.sapd_r_baden = (Q.sapd_r_baden / Q.total_r_baden) * 100;
    Q.uspd_r_baden = (Q.uspd_r_baden / Q.total_r_baden) * 100;
    Q.kpd_r_baden = (Q.kpd_r_baden / Q.total_r_baden) * 100;
    Q.ddp_r_baden = (Q.ddp_r_baden / Q.total_r_baden) * 100;
    Q.lvp_r_baden = (Q.lvp_r_baden / Q.total_r_baden) * 100;
    Q.dvp_r_baden = (Q.dvp_r_baden / Q.total_r_baden) * 100;
    Q.dnvp_r_baden = (Q.dnvp_r_baden / Q.total_r_baden) * 100;
    Q.nsdap_r_baden = (Q.nsdap_r_baden / Q.total_r_baden) * 100;
    Q.other_r_baden = (Q.other_r_baden / Q.total_r_baden) * 100;
    Q.kvp_r_baden = (Q.kvp_r_baden / Q.total_r_baden) * 100;
    Q.dnf_r_baden = (Q.dnf_r_baden / Q.total_r_baden) * 100;
    Q.z_r_baden = (Q.z_r_baden / Q.total_r_baden) * 100;
    Q.nsfb_r_baden = (Q.nsfb_r_baden / Q.total_r_baden) * 100;
}

let wp_share = 0.7;
if (Q.stolper_program_adopted) wp_share -= 0.1;
if (Q.csvd_exists) wp_share -= 0.3;
if (Q.chancellor == "Brüning") wp_share -= 0.2;
let csvd_share = 0.0;
if (Q.csvd_exists) csvd_share += 0.3;
let cnbl_share = 0.0;
if (Q.cnbl_exists) cnbl_share += 0.2;
let true_other_share = 0.3;
if (Q.csvd_exists) true_other_share -= 0.2;

let total_share = wp_share + csvd_share + cnbl_share + true_other_share;

wp_share = (wp_share / total_share);
csvd_share = (csvd_share / total_share);
cnbl_share = (cnbl_share /total_share);
true_other_share = (true_other_share / total_share);


Q.wp_baden_elections_vote = Q.other_baden_elections_vote*wp_share;
Q.wp_r_baden = Q.other_r_baden*wp_share;

Q.csvd_baden_elections_vote = Q.other_baden_elections_vote*csvd_share;
Q.csvd_r_baden = Q.other_r_baden*csvd_share;

Q.cnbl_baden_elections_vote = Q.other_baden_elections_vote*cnbl_share;
Q.cnbl_r_baden = Q.other_r_baden*cnbl_share;           

Q.true_other_baden_elections_vote = Q.other_baden_elections_vote*true_other_share;
Q.true_other_r_baden = Q.other_r_baden*true_other_share;

function allocateSeats(percentages, totalSeats = 88) {
    const exactSeats = {};
    const flooredSeats = {};
    const remainders = [];

    let totalFlooredSeats = 0;
    for (const party in percentages) {
        const exact = (percentages[party] * totalSeats) / 100;
        const floored = Math.floor(exact);
        const remainder = exact - floored;

        exactSeats[party] = exact;
        flooredSeats[party] = floored;
        totalFlooredSeats += floored;

        remainders.push({ party, remainder });
    }

    const seatsToDistribute = totalSeats - totalFlooredSeats;
    remainders.sort((a, b) => b.remainder - a.remainder);

    for (let i = 0; i < seatsToDistribute; i++) {
        flooredSeats[remainders[i].party]++;
    }

    return flooredSeats;
}

const inputPercentages = {
    spd_r_baden: Q.spd_r_baden,
    uspd_r_baden: Q.uspd_r_baden,
    sapd_r_baden: Q.sapd_r_baden,
    kpd_r_baden: Q.kpd_r_baden,
    ddp_r_baden: Q.ddp_r_baden,
    lvp_r_baden: Q.lvp_r_baden,
    dvp_r_baden: Q.dvp_r_baden,
    dnvp_r_baden: Q.dnvp_r_baden,
    nsdap_r_baden: Q.nsdap_r_baden,
    cnbl_r_baden: Q.cnbl_r_baden,
    csvd_r_baden: Q.csvd_r_baden,
    wp_r_baden: Q.wp_r_baden,
    true_other_r_baden: Q.true_other_r_baden,
    kvp_r_baden: Q.kvp_r_baden,
    dnf_r_baden: Q.dnf_r_baden,
    z_r_baden: Q.z_r_baden,
    nsfb_r_baden: Q.nsfb_r_baden
};

const allocatedSeats = allocateSeats(inputPercentages);

for (const party in allocatedSeats) {
    Q[party] = parseFloat(((allocatedSeats[party] * 100) / 88).toFixed(1));
}

Q.other_r_baden = Q.wp_r_baden + Q.true_other_r_baden + Q.csvd_r_baden + Q.cnbl_r_baden;

Q.left_coalition_baden = parseFloat((Q.spd_r_baden + Q.kpd_r_baden + Q.sapd_r_baden + Q.uspd_r_baden).toFixed(1));
Q.grand_coalition_baden = parseFloat((Q.ddp_r_baden + Q.dvp_r_baden + Q.lvp_r_baden + Q.spd_r_baden + Q.z_r_baden).toFixed(1));
Q.right_coalition_baden = parseFloat((Q.dnvp_r_baden + Q.nsdap_r_baden + Q.dvp_r_baden + Q.other_r_baden).toFixed(1));
Q.true_bourgeois_coalition_baden = parseFloat((Q.ddp_r_baden + Q.dvp_r_baden + Q.lvp_r_baden + Q.kvp_r_baden + Q.true_other_r_baden + Q.z_r_baden + Q.wp_r_baden).toFixed(1));
Q.weimar_coalition_baden = parseFloat((Q.spd_r_baden + Q.ddp_r_baden + Q.lvp_r_baden + Q.z_r_baden).toFixed(1));

Q.wp_baden_elections_vote = (Q.wp_baden_elections_vote != undefined ? parseFloat(Q.wp_baden_elections_vote.toFixed(1)) : 0);
Q.true_other_baden_elections_vote = (Q.true_other_baden_elections_vote != undefined ? parseFloat(Q.true_other_baden_elections_vote.toFixed(1)) : 0);
Q.csvd_baden_elections_vote = (Q.csvd_baden_elections_vote != undefined ? parseFloat(Q.csvd_baden_elections_vote.toFixed(1)) : 0);
Q.cnbl_baden_elections_vote = (Q.cnbl_baden_elections_vote != undefined ? parseFloat(Q.cnbl_baden_elections_vote.toFixed(1)) : 0);             
Q.wp_r_baden = (Q.wp_r_baden != undefined ? parseFloat(Q.wp_r_baden.toFixed(1)) : 0);
Q.true_other_r_baden = (Q.true_other_r_baden != undefined ? parseFloat(Q.true_other_r_baden.toFixed(1)) : 0);
Q.csvd_r_baden = (Q.csvd_r_baden != undefined ? parseFloat(Q.csvd_r_baden.toFixed(1)) : 0);
Q.cnbl_r_baden = (Q.cnbl_r_baden != undefined ? parseFloat(Q.cnbl_r_baden.toFixed(1)) : 0);
             

!}
on-display: {!
data = [{
    "id": "kpd",
    "legend": "KPD",
    "name": "KPD",
    "seats": Math.round(Q.kpd_r_baden * 0.88),
}];

if (Q.sapd_formed && Q.sapd_r_baden) {
    data.push({
        "id": "sapd",
        "legend": "SAPD",
        "name": "SAPD",
        "seats": Math.round(Q.sapd_r_baden * 0.88),
    });
}

if (Q.uspd_r_baden) {
    data.push({
        "id": "uspd",
        "legend": "USPD",
        "name": "USPD",
        "seats": Math.round(Q.uspd_r_baden * 0.88),
    });
}
             
data = data.concat([{
    "id": "spd",
    "legend": "SPD",
    "name": "SPD",
    "seats": Math.round(Q.spd_r_baden * 0.88),
}]);

if (Q.ddp_r_baden && !Q.lvp_formed) {
    data.push({
        "id": "ddp",
        "legend": Q.ddp_name,
        "name": Q.ddp_name,
        "seats": Math.round(Q.ddp_r_baden * 0.88),
    });
}

if (Q.lvp_r_baden && Q.lvp_formed) {
    data.push({
        "id": "lvp",
        "legend": "LVP",
        "name": "LVP",
        "seats": Math.round(Q.lvp_r_baden * 0.88),
    });
}


data.push({
    "id": "z",
    "legend": "Z",
    "name": "Z",
    "seats": Math.round(Q.z_r_baden * 0.88),
});


if (Q.true_other_r_baden) {
    data.push({
        "id": "other",
        "legend": "Other",
        "name": "Others",
        "seats": Math.round(Q.true_other_r_baden * 0.88),
    });
}

if (Q.dvp_r_baden && !Q.lvp_formed && Q.dvp_exist) {
    data.push({
        "id": "dvp",
        "legend": "DVP",
        "name": "DVP",
        "seats": Math.round(Q.dvp_r_baden * 0.88),
    });
}
           
if (Q.wp_r_baden) {
    data.push({
        "id": "wp",
        "legend": "WP",
        "name": "WP",
        "seats": Math.round(Q.wp_r_baden * 0.88),
    });
}            
             

if (Q.kvp_formed && Q.kvp_r_baden) {
    data.push({
        "id": "kvp",
        "legend": "KVP",
        "name": "KVP",
        "seats": Math.round(Q.kvp_r_baden * 0.88),
    });
}

if (Q.csvd_exists && Q.csvd_r_baden) {
    data.push({
        "id": "farm3",
        "legend": "CSVD",
        "name": "CSVD",
        "seats": Math.round(Q.csvd_r_baden * 0.88),
    });
}

if (Q.cnbl_exists && Q.cnbl_r_baden) {
    data.push({
        "id": "farm2",
        "legend": "CBNL",
        "name": "CNBL",
        "seats": Math.round(Q.cnbl_r_baden * 0.88),
    });
}

if (Q.dnvp_r_baden) {             
data = data.concat([{
    "id": "dnvp",
    "legend": "DNVP",
    "name": "DNVP",
    "seats": Math.round(Q.dnvp_r_baden * 0.88),
}]);
}
  
data.push({
    "id": "nsfb",
    "legend": "NSFB",
    "name": "NSFB",
    "seats": Math.round(Q.nsfb_r_baden * 0.88),
});

data = data.concat([{
    "id": "nsdap",
    "legend": "NSDAP",
    "name": "NSDAP",
    "seats": Math.round(Q.nsdap_r_baden * 0.88),
}]);

if (window && d3) {
    var width = 500;
    var height = 500;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50;
        height = width;
        document.getElementById("baden_landtag").style.height = screenWidth/2 + "px";
    }
    var parliament = d3.parliament();
    parliament.width(width).height(height).innerRadiusCoef(0.4);
    parliament.enter.fromCenter(true).smallToBig(true);
    parliament.exit.toCenter(false).bigToSmall(true);
    d3.select("#baden_landtag").datum(data).call(parliament);
}
!}
go-to: baden_coalition_menu

