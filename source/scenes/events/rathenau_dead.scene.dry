title: <span style="color: #D3C24D;">**Walther Rathenau**</span> shot dead!
subtitle: Foreign Minister <span style="color: #D3C24D;">**Walther Rathenau**</span> has been shot by terrorists...
new-page: true
on-arrival: rathenau_dead = 1; foreign_minister = "Wirth"; foreign_minister_party = "Z"; inflation += 1.6
