title: Bremen Landtag Election
view-if: (year == 1922 and month == 6 and not bremen_election_seen) or (bremen_election_2_trigger_time == time and bremen_election_seen_time != time)
new-page: true
tags: event
on-arrival: bremen_election_seen += 1 if bremen_election_seen; bremen_election_seen = 1 if not bremen_election_seen; bremen_election_seen_time = time
priority: 2
on-display: {!  
    var cardEl = document.createElement('div');  
    cardEl.className = "face-figure2";  

    var image = new Image();  
    image.className = "face-img";  
    image.src = "img/states.png";  

    cardEl.appendChild(image);  
    var contentDiv = document.querySelector("#page #mid_panel #content");
    contentDiv.appendChild(cardEl);
!}

= Elections, [+ month : month +] [+ year +]

The Bremen state elections are to be held now.

- @bremen: May we do our best...

@bremen
on-arrival: {!

var bremen_adjustment_factors = {
    spd: 1.27,
    sapd: 1,
    uspd: 0.82,
    kpd: 1.2,
    z: 0.15,
    ddp: 1.6,
    lvp: 1.58,
    dvp: 1.5,
    dnvp: 0.5,
    nsdap: 0.6,
    nsfb: 1.03,
    other: 1.12,
    kvp: 0.88,
    dnf: 0.3
};

Q.spd_r_bremen = 0;
Q.sapd_r_bremen = 0;
Q.uspd_r_bremen = 0;
Q.kpd_r_bremen = 0;
Q.ddp_r_bremen = 0;
Q.lvp_r_bremen = 0;
Q.dvp_r_bremen = 0;
Q.dnvp_r_bremen = 0;
Q.nsdap_r_bremen = 0;
