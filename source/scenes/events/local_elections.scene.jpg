United Left Coalition (<span style="color: #c00000;">**SPD**</span> + <span style="color: #A10000;">**USPD**</span> + <span style="color: #700000;">**KPD**</span>[? if sapd_formed:&nbsp;+ <span style="color: #9B0000;">**SAPD**</span>?] + <span style="color: #C43988;">**KPO**</span>): [+ left_coalition_hamburg +]% 

Weimar Coalition (<span style="color: #c00000;">**SPD**</span> + [? if not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span>?][? if lvp_formed: <span style="color: #FFCC00;">**LVP**</span>?]<span style="color: #000000;"> + **Z**</span>): [+ weimar_coalition_hamburg +]% 

Grand Coalition (<span style="color: #c00000;">**SPD**</span> + [? if not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span> + <span style="color: #C0A054;">**DVP**</span>?][? if lvp_formed: <span style="color: #FFCC00;">**LVP**</span>?]<span style="color: #000000;"> + **Z**</span> + <span style="color: #AFAFAF;">**Others**</span>): [+ grand_coalition_hamburg +]%

Bourgeois Coalition (<span style="color: #000000;">**Z**</span> + [? if not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span> + <span style="color: #C0A054;">**DVP**</span>?][? if lvp_formed: <span style="color: #FFCC00;">**LVP**</span>?] [? if kvp_formed :+ <span style="color: #0087DC;">**KVP**</span> ?]+ <span style="color: #0087DC;">**VRP**</span> + <span style="color: #b8996f;">**WP**</span> + <span style="color: #AFAFAF;">**Others**</span> + [? if kvp_formed:&nbsp;+ <span style="color: #0087DC;">**KVP**</span> ?]): [+ true_bourgeois_coalition_hamburg +]%

Right-Wing Coalition (<span style="color: #3E88B3;">**DNVP**</span> + <span style="color: #7A3C00;">**NSDAP**</span> + <span style="color: #C0A054;">**DVP**</span> + <span style="color: #b8996f;">**WP**</span>): [+ right_coalition_hamburg +]%

@hamburg_coalition_menu


- @weimar_coalition_hamburg
- @grand_coalition_hamburg
- @bourgeois_coalition_hamburg
- @left_coalition_hamburg
- @spd_majority_hamburg
- @right_wing_coalition_hamburg
- @no_coalition_hamburg

@weimar_coalition_hamburg
title: A Weimar Coalition will be formed
choose-if: weimar_coalition_hamburg > 50 and z_relation >= 25
on-arrival: hamburg_election_2_trigger_time = time + 48; z_relation += 2; ddp_relation += 3

@grand_coalition_hamburg
title: A Grand Coalition will be formed
choose-if: grand_coalition_hamburg > 50 and z_relation >= 25 and dvp_relation 35
on-arrival: hamburg_election_2_trigger_time = time + 48; z_relation += 2; dvp_relation += 3

@bourgeois_coalition_hamburg
title: A bourgeois coalition must be formed
choose-if: true_bourgeois_coalition_hamburg > 50
view-if: weimar_coalition_hamburg < 50 and right_coalition_hamburg < 50
on-arrival: hamburg_election_2_trigger_time = time + 48

@left_coalition_hamburg
title: A Coalition of the Left will be formed
subtitle: We will work alongside the KPD
choose-if: left_coalition_hamburg > 50 and kpd_relation >= 40
on-arrival: hamburg_election_2_trigger_time = time + 48; unemployed_kpd += 3; new_middle_others -= 2; new_middle_dvp -= 1; new_middle_spd += 1

@spd_majority_hamburg
title: We don't need any coalition partners
view-if: spd_r_hamburg > 80
on-arrival: hamburg_election_2_trigger_time = time + 48; workers_spd += 1; workers_dnvp -= 2; new_middle_spd += 1; new_middle_others -= 1

@right_wing_coalition_hamburg
title: The DNVP and DVP will work alongside the NSDAP
subtitle: This should not have happened
choose-if: right_coalition_hamburg > 50
view-if: right_coalition_hamburg > 50
on-arrival: hamburg_election_2_trigger_time = time + 48; rural_nsdap += 2; dvp_relation -= 2

This can't end well...

@no_coalition_hamburg
title: There is no possible government arrangement
subtitle: New elections will be called...
on-arrival: hamburg_election_2_trigger_time = time + 3; new_middle_dnvp += 1
view-if: weimar_coalition_hamburg < 50 and right_coalition_hamburg < 50
