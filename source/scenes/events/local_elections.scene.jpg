Q.kvp_r_hamburg = 0;
Q.dnf_r_hamburg = 0;

Q.spd_hamburg_elections_vote = 0;
Q.sapd_hamburg_elections_vote = 0;
Q.uspd_hamburg_elections_vote = 0;
Q.kpd_hamburg_elections_vote = 0;
Q.ddp_hamburg_elections_vote = 0;
Q.lvp_hamburg_elections_vote = 0;
Q.dvp_hamburg_elections_vote = 0;
Q.dnvp_hamburg_elections_vote = 0;
Q.nsdap_hamburg_elections_vote = 0;
Q.z_hamburg_elections_vote = 0;
Q.nsfb_hamburg_elections_vote = 0;
Q.other_hamburg_elections_vote = 0;
Q.kvp_hamburg_elections_vote = 0;
Q.dnf_hamburg_elections_vote = 0;

if (Q.new_middle_spd_normalized + Q.old_middle_spd_normalized >= 30) hamburg_adjustment_factors.spd += 0.1;
if (Q.spd_r < 100) hamburg_adjustment_factors.uspd += 0.3;
if (Q.spd_r < 70) hamburg_adjustment_factors.kpd += 0.1;
if (Q.workers_spd_normalized >= 70) hamburg_adjustment_factors.spd += 0.1;
Q.spd_hamburg_elections_vote = Q.spd_votes*hamburg_adjustment_factors.spd;
Q.sapd_hamburg_elections_vote = Q.sapd_votes*hamburg_adjustment_factors.sapd;
Q.uspd_hamburg_elections_vote = Q.uspd_votes*hamburg_adjustment_factors.uspd;
Q.kpd_hamburg_elections_vote = Q.kpd_votes*hamburg_adjustment_factors.kpd;
if (Q.stolper_program_adopted) hamburg_adjustment_factors.ddp += 0.2;
Q.ddp_hamburg_elections_vote = Q.ddp_votes*hamburg_adjustment_factors.ddp;
Q.lvp_hamburg_elections_vote = Q.lvp_votes*hamburg_adjustment_factors.lvp;
Q.dvp_hamburg_elections_vote = Q.dvp_votes*hamburg_adjustment_factors.dvp;
if (Q.dnvp_ideology == "Moderate") hamburg_adjustment_factors.dnvp -= 0.1;
Q.dnvp_hamburg_elections_vote = Q.dnvp_votes*hamburg_adjustment_factors.dnvp;
Q.nsdap_hamburg_elections_vote = Q.nsdap_votes*hamburg_adjustment_factors.nsdap;
Q.z_hamburg_elections_vote = Q.z_votes*hamburg_adjustment_factors.z;
Q.nsfb_hamburg_elections_vote = Q.nsfb_votes*hamburg_adjustment_factors.nsfb;
if (Q.stolper_program_adopted) hamburg_adjustment_factors.other -= 0.1;
Q.other_hamburg_elections_vote = Q.other_votes*hamburg_adjustment_factors.other;
Q.kvp_hamburg_elections_vote = Q.kvp_votes*hamburg_adjustment_factors.kvp;
Q.dnf_hamburg_elections_vote = Q.dnf_votes*hamburg_adjustment_factors.dnf;

Q.total_votes_hamburg = Q.spd_hamburg_elections_vote + Q.sapd_hamburg_elections_vote + Q.kpd_hamburg_elections_vote + Q.ddp_hamburg_elections_vote + Q.lvp_hamburg_elections_vote + Q.dvp_hamburg_elections_vote + Q.dnvp_hamburg_elections_vote + Q.nsdap_hamburg_elections_vote + Q.other_hamburg_elections_vote + Q.kvp_hamburg_elections_vote + Q.dnf_hamburg_elections_vote + Q.uspd_hamburg_elections_vote + Q.z_hamburg_elections_vote + Q.nsfb_hamburg_elections_vote;

if (Q.total_votes_hamburg > 0) {
    Q.spd_hamburg_elections_vote = (Q.spd_hamburg_elections_vote / Q.total_votes_hamburg) * 100;
