title: Hamburg Landtag Election
view-if: (year == 1924 and month == 12 and not hamburg_election_seen) or (hamburg_election_2_trigger_time == time and hamburg_election_seen_time != time)
new-page: true
tags: event
on-arrival: hamburg_election_seen += 1 if hamburg_election_seen; hamburg_election_seen = 1 if not hamburg_election_seen; hamburg_election_seen_time = time
priority: 2
on-display: {!  
    var cardEl = document.createElement('div');  
    cardEl.className = "face-figure2";  

    var image = new Image();  
    image.className = "face-img";  
    image.src = "img/states.png";  

    cardEl.appendChild(image);  
    var contentDiv = document.querySelector("#page #mid_panel #content");
    contentDiv.appendChild(cardEl);
!}

= Elections, [+ month : month +] [+ year +]

The Hamburg state elections are to be held now.

- @hamburg: May we do our best...

@hamburg
on-arrival: {!

var hamburg_adjustment_factors = {
    spd: 1.25,
    sapd: 0.98,
    uspd: 0.86,
    kpd: 1.61,
    z: 0.1,
    ddp: 1.8,
    lvp: 1.62,
    dvp: 1.4,
    dnvp: 0.8,
    nsdap: 0.97,
    nsfb: 0.8,
    other: 0.53,
    kvp: 0.8,
    dnf: 0.5
};

Q.spd_r_hamburg = 0;
Q.sapd_r_hamburg = 0;
Q.uspd_r_hamburg = 0;
Q.kpd_r_hamburg = 0;
Q.ddp_r_hamburg = 0;
