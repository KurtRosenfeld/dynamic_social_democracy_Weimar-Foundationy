[? if lvp_formed: {!<tr><td><div class="box" style='background-color:#FFCC00'> </div> !} LVP: {!</td><td!} **[+ lvp_waldeck_elections_vote +]%** {!</td><td!} **[+ lvp_r_waldeck +]%**  {!</td></tr>!} ?]

[? if year == 1922: {!<tr><td><div class="box" style='background-color:#CEDD8A'> </div> !} WV: {!</td><td!} **[+ dvp_waldeck_elections_vote +]%** {!</td><td!} **[+ dvp_r_waldeck +]%**  {!</td></tr>!} ?]

