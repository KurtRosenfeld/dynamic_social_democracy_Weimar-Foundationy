[? if year == 1925: {!<tr><td><div class="box" style='background-color:#3E88B3'> </div> !} DNVP: {!</td><td!} **[+ dnvp_waldeck_elections_vote +]%** {!</td><td!} **[+ dnvp_r_waldeck +]%**  {!</td></tr>!} ?]

{!<tr><td><div class="box" style='background-color:#006400'> </div> !} LB: {!</td><td!} **[+ other_waldeck_elections_vote +]%** {!</td><td!} **[+ other_r_waldeck +]%**  {!</td></tr>!}
{!</tr>!}
<hr id="read-marker">

Worker Coalition (<span style="color: #c00000;">**SPD**</span>[? if uspd_r_waldeck: + <span style="color: #A10000;">**USPD**</span>?][? if hb_r_waldeck: + <span style="color: #CB7F00;">**Craftsmen**</span>?]): [+ worker_coalition_waldeck +]% 

Social Liberal Coalition (<span style="color: #c00000;">**SPD**</span>[? if hb_r_waldeck: + <span style="color: #CB7F00;">**Craftsmen**</span>?] + [? if not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span>?][? if lvp_formed: <span style="color: #FFCC00;">**LVP**</span>?]): [+ social_liberal_coalition_waldeck +]%

Right-Wing Coalition (<span style="color: #006400;">**LB**</span> + <span style="color: #3E88B3;">**DNVP**</span> + [? if not lvp_formed: <span style="color: #C0A054;">**DVP**</span>?][? if lvp_formed: <span style="color: #FFCC00;">**LVP**</span>?]): [+ right_coalition_waldeck +]%

@waldeck_coalition_menu

- @workers_coalition_waldeck
- @soc_lib_coalition_waldeck
- @right_coalition_waldeck
- @spd_only_waldeck

@workers_coalition_waldeck
title: A proletarian coalition in the German outback?
choose-if: worker_coalition_waldeck >= 50
view-if: worker_coalition_waldeck >= 40
on-arrival: waldeck_gov = "Social-Democratic"; rural_spd += 2; rural_other -= 1; rural_dnvp -= 2; dvp_relation -= 5; pro_republic += 1

@soc_lib_coalition_waldeck
title: A Social-Liberal Coalition will be formed.
choose-if: social_liberal_coalition_waldeck >= 50 and ddp_relation >= 20
on-arrival: ddp_relation += 3; waldeck_gov = "Social-Liberal"; rural_spd += 1; rural_other -= 2; rural_dnvp -= 1; pro_republic += 1

@right_coalition_waldeck
title: The right forms a government led by the <span style="color: #006400;">**Rural League**</span>.
subtitle: This came as expected...
choose-if: right_coalition_waldeck >= 50
on-arrival: waldeck_gov = "Right"; rural_spd -= 1; rural_other += 2; rural_dnvp -= 1

@spd_only_waldeck
title: THE <span style="color: #c00000;">**SPD**</span> WILL GOVERN ALONE IN WALDECK?!?!?!?
choose-if: spd_r_waldeck >= 50
view-if: spd_r_waldeck >= 50
on-arrival: waldeck_gov = "SPD"; rural_spd += 3; rural_other -= 2; rural_dnvp -= 2; dvp_relation -= 10; pro_republic += 2


