<div id="waldeck-tooltip" class="tooltip-group">
    <strong style="display: block; text-align: center;">Waldeck Politics</strong>
 <div style="font-size: 0.9em; text-align: center; margin-bottom: 4px;">
    Landtag (<span class="total-seats">[+ waldeck_seats +]</span> seats)
  </div>
