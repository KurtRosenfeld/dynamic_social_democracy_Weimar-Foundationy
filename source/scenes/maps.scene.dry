@provinces_political 
go-to: map_menu

{!<table>!} 
[? if kpd_relation >= 25: {!<tr><td><div class="box" style='background-color:#8E0000'> </div> Left Coalition </td></tr>!} ?]

{!<tr><td><div class="box" style='background-color:#A51E5A'> </div> Social-Democratic Coalition </td></tr>!}

{!<tr><td><div class="box" style='background-color:#c10000'> </div> SPD-only </td></tr>!}

[? if year >= 1929: {!<tr><td><div class="box" style='background-color:#6C168E'> </div> Popular Front Coalition </td></tr>!} ?]

{!<tr><td><div class="box" style='background-color:#FC6D6D'> </div> Weimar Coalition </td></tr>!}

[? if bavaria_gov == "Anti-BVP" or bavaria_gov == "Traffic": {!<tr><td><div class="box" style='background-color:#DD6F9C'> </div> Bavaria Coaliation including the SPD </td></tr>!} ?]

{!<tr><td><div class="box" style='background-color:#5E405A'> </div> Social-Catholic Coalition </td></tr>!}

{!<tr><td><div class="box" style='background-color:#DD8D1B'> </div> Social-Liberal Coalition (including DVP) </td></tr>!}

{!<tr><td><div class="box" style='background-color:#A2B725'> </div> Grand Coalition </td></tr>!}

{!<tr><td><div class="box" style='background-color:#818181'> </div> Bourgeois Coalition </td></tr>!}

[? if bavaria_gov == "BVP": {!<tr><td><div class="box" style='background-color:#11EDEA'> </div> BVP-only </td></tr>!} ?]

{!<tr><td><div class="box" style='background-color:#0F4989'> </div> Bourgeois Right Coalition </td></tr>!}

[? if nsdap_votes >= 22: {!<tr><td><div class="box" style='background-color:#563129'> </div> Far-Right Coalition </td></tr>!} ?]

{!</table>!}

